[include]
	path = ~/.gitconfig.local
[core]
	pager = delta
	ignorecase = false
	editor = vim
	quotepath = false
	autoCRLF = false
	pager = delta
	fsmonitor = true
[fetch]
	prune = true
	prunetags = true
[push]
	default = current
[pull]
	rebase = false
[color]
	ui = true
[credential "https://github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
[init]
	defaultBranch = main
[diff]
	colorMoved = default
	algorithm = histogram
	context = 10
[merge]
	conflictstyle = zdiff3
[delta]
	navigate = true
	light = false
[interactive]
	diffFilter = delta --color-only
[alias]
	st = status
	s = status --short --branch
	ci = commit
	sw = switch
	new = switch -c
	cp = cherry-pick
	cm = commit -m
	br = branch
	rbr = branch -a
	up = pull --ff-only
	pub = push -u origin HEAD
	stash-save = stash push -u
	stash-load = stash pop
	la = log --oneline --decorate --graph --branches --tags --remotes --all
	lg = log --graph --date=short --pretty=format:'%C(auto)%h %C(bold blue)%ad %C(bold green)%<(18,trunc)%an%C(reset) %C(auto)%d %s'
	recent = for-each-ref --sort=-committerdate --count=12 --format='%(color:cyan)%(refname:short)%(color:reset) %(color:yellow)%(committerdate:relative)%(color:reset) %(contents:subject)' refs/heads refs/remotes
	today = log --since=midnight --oneline --decorate --all
	unstage = restore --staged
	wip = !"git commit -m 'wip'"
	aliases = !"git config --get-regexp '^alias\\.' | colrm 1 6 | sed 's/[ ]/ = /'"
	merged = branch --merged
	delete = branch -d
	force-delete = branch -D
	last = log -1 HEAD --stat
	current = !"git rev-parse --abbrev-ref HEAD"
	fixit = commit --amend --no-edit
	please = push --force-with-lease --force-if-includes
	root = !git show-branch | grep \"*\" | grep -v \"$(git rev-parse --abbrev-ref HEAD)\" | head -n 1 | sed \"s/.*\\\\[\\\\([^]]*\\\\)\\\\].*/\\\\1/\"
[ghq]
	root = ~/dev
	user = takuyaw-w
[column]
	ui = auto
[branch]
	sort = -committerdate
[commit]
	verbose = true
[rerere]
	enabled = true
[help]
	autocorrect = 10
